# Alloy — environment variables.
#
# Copy to .env and fill in what you have. Phase 0 only requires:
#   POSTGRES_* (defaults work for docker-compose)
#   AZURE_OPENAI_* (for the generate/echo smoke endpoint)
#
# Everything else can stay blank until the phase that needs it; app.core.config
# marks optional settings explicitly and guards at call time.

# ─── App metadata ───────────────────────────────────────────────────
ENVIRONMENT=local                      # local | staging | production
LOG_LEVEL=INFO

# ─── CORS / hosts ───────────────────────────────────────────────────
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173

# ─── Database (Postgres — Neon in prod) ─────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=alloy
POSTGRES_PASSWORD=alloy
POSTGRES_DB=alloy

# ─── Redis (Arq + cache + rate-limit — Upstash in prod) ─────────────
REDIS_URL=redis://localhost:6379/0

# ─── Clerk (auth — Phase 0 optional; unset = dev bootstrap) ─────────
# Create a Clerk project at https://dashboard.clerk.com, then paste the
# issuer (ends in .clerk.accounts.dev) and the Publishable Key.
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
VITE_CLERK_PUBLISHABLE_KEY=            # frontend only; safe to ship in client bundle

# ─── Azure OpenAI (Phase 0: required for /generate/echo) ────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Second region (LiteLLM fallback — deploy in East US 2 + Sweden Central
# from day one per roadmap §5; weighted load-balance via LiteLLM).
AZURE_OPENAI_ENDPOINT_FALLBACK=
AZURE_OPENAI_API_KEY_FALLBACK=

# ─── Fallback LLM providers (Phase 1+ — LiteLLM cascade) ────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Apply models (Phase 2) ─────────────────────────────────────────
MORPH_API_KEY=
RELACE_API_KEY=

# ─── Observability ──────────────────────────────────────────────────
SENTRY_DSN=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Object storage (Phase 1 — Cloudflare R2) ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ─── Sandboxes (Phase 1 — Daytona Cloud) ────────────────────────────
DAYTONA_API_URL=
DAYTONA_API_KEY=

# ─── Local sandbox manager (Phase 1 wk3-4 Daytona stand-in) ──────────
# Leave as defaults on a dev machine; on staging/prod we swap the
# LocalSandboxManager for the Daytona-backed one via DI.
ALLOY_WORKSPACES_ROOT=~/.alloy/workspaces
SANDBOX_PORT_RANGE_START=20000
SANDBOX_PORT_RANGE_END=29999
DOCKER_BINARY=docker

# ─── GitHub App (Phase 3) ───────────────────────────────────────────
# Create a GitHub App (not an OAuth App — roadmap §7 for why).
# Paste the raw PEM with literal "\n" escapes, or point GITHUB_APP_PRIVATE_KEY_FILE.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── Vercel (Phase 3 — frontend deploy target) ──────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ─── Billing (Phase 4 — Stripe Billing + in-app credit ledger) ──────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
